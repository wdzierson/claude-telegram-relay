{
  "servers": [
    {
      "name": "google",
      "command": "npx",
      "args": ["-y", "@presto-ai/google-workspace-mcp"],
      "approvalPolicy": "destructive"
    },
    {
      "name": "github",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your-github-pat"
      },
      "approvalPolicy": "destructive"
    },
    {
      "name": "filesystem",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/you/Documents"],
      "approvalPolicy": "destructive"
    },
    {
      "name": "brave-search",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "your-brave-api-key"
      },
      "approvalPolicy": "never"
    },
    {
      "name": "playwright",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "env": { "PLAYWRIGHT_MCP_HEADLESS": "true" },
      "approvalPolicy": "destructive",
      "scope": "background"
    },
    {
      "name": "stagehand",
      "command": "npx",
      "args": ["-y", "@browserbasehq/mcp-server-browserbase"],
      "env": {
        "BROWSERBASE_API_KEY": "your-browserbase-api-key",
        "BROWSERBASE_PROJECT_ID": "your-browserbase-project-id",
        "GEMINI_API_KEY": "your-gemini-api-key"
      },
      "approvalPolicy": "destructive",
      "scope": "background"
    },
    {
      "name": "notion",
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\":\"Bearer your-notion-token\",\"Notion-Version\":\"2022-06-28\"}"
      },
      "approvalPolicy": "destructive"
    },
    {
      "name": "slack",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "xoxb-your-slack-bot-token",
        "SLACK_TEAM_ID": "your-team-id"
      },
      "approvalPolicy": "destructive"
    },
    {
      "name": "memory",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "approvalPolicy": "never"
    },
    {
      "name": "supabase",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--access-token", "your-supabase-access-token"],
      "approvalPolicy": "destructive"
    },
    {
      "name": "image-gen",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/replicate-mcp@latest"],
      "env": {
        "REPLICATE_API_TOKEN": "your-replicate-api-token"
      },
      "approvalPolicy": "destructive"
    }
  ]
}
